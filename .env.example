# LLM Providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
DEFAULT_LLM_PROVIDER=anthropic
DEFAULT_LLM_MODEL=claude-3-5-sonnet-latest

# Search Provider
SEARCH_PROVIDER=tavily
TAVILY_API_KEY=
EXA_API_KEY=
SERPAPI_API_KEY=

# GitHub
GITHUB_TOKEN=
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=trend2poc-knowledge-base
GITHUB_DEFAULT_BRANCH=main

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# API
API_SECRET_KEY=
API_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:3000

# Pipeline
MIN_EVAL_SCORE=7.0
TARGET_EVAL_SCORE=8.0
AUTO_PUSH_TO_GITHUB=false
MAX_TOPICS_PER_RUN=5
MAX_SOURCES_PER_TOPIC=12
SOURCE_CONFIDENCE_THRESHOLD=0.70

# Redis (optional — short-term state cache for active runs)
# If set alongside Supabase, DualCheckpointer activates automatically
REDIS_URL=redis://localhost:6379/0
REDIS_STATE_TTL_SECONDS=86400

# Facebook (optional — social publishing connector)
# Generate a Page Access Token from: https://developers.facebook.com/tools/explorer/
# Required permissions: pages_read_engagement, pages_manage_posts
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=
FACEBOOK_AUTO_POST=false

# Cost Tracking
ENABLE_COST_TRACKING=true
MAX_RUN_COST_USD=3.00
